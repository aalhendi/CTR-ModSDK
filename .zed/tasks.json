  {
    "label": "lsp: refresh compile_commands",
    "command": "uv",
    "args": ["run", "python", "tools/dev/ctr_task.py", "lsp-refresh"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never"
  },
